{
  "info": {
    "name": "1. Auth (Xác Thực)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "managerToken", "value": "" },
    { "key": "consultantToken", "value": "" }
  ],
  "item": [
    {
      "name": "TC-AUTH-01: Đăng nhập thành công (MANAGER)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
        "const json = pm.response.json();",
        "pm.test('Có accessToken', () => pm.expect(json).to.have.property('accessToken'));",
        "pm.test('Có user info', () => pm.expect(json.user).to.have.keys(['id','email','fullName','role']));",
        "if (json.accessToken) pm.collectionVariables.set('managerToken', json.accessToken);"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@billing.vn\",\n  \"password\": \"123456\"\n}" },
        "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
      }
    },
    {
      "name": "TC-AUTH-02: Đăng nhập sai mật khẩu",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@billing.vn\",\n  \"password\": \"satmatkau\"\n}" },
        "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
      }
    },
    {
      "name": "TC-AUTH-03: Email không tồn tại",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"khongtontai@billing.vn\",\n  \"password\": \"123456\"\n}" },
        "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
      }
    },
    {
      "name": "TC-AUTH-04: Lấy thông tin tài khoản hiện tại",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
        "pm.test('Trả về thông tin user', () => pm.expect(pm.response.json()).to.have.property('email'));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/account", "host": ["{{baseUrl}}"], "path": ["account"] }
      }
    },
    {
      "name": "TC-AUTH-05: Đăng xuất",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/logout", "host": ["{{baseUrl}}"], "path": ["logout"] }
      }
    },
    {
      "name": "TC-AUTH-06: Dùng token sau khi đăng xuất (bị blacklist)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 401 — token bị blacklist', () => pm.response.to.have.status(401));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/account", "host": ["{{baseUrl}}"], "path": ["account"] }
      }
    },
    {
      "name": "TC-AUTH-07: Gọi API không có token",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 401 — không có token', () => pm.response.to.have.status(401));",
        "pm.test('Trả về JSON không redirect', () => pm.response.to.be.json);"
      ] } }],
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/records", "host": ["{{baseUrl}}"], "path": ["records"] }
      }
    }
  ]
}
