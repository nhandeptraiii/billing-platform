{
  "info": {
    "name": "2. User Management (Quản Lý Người Dùng)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "managerToken", "value": "" },
    { "key": "consultantToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "TC-USER-00: Login lại lấy token MANAGER",
      "event": [{ "listen": "test", "script": { "exec": [
        "const json = pm.response.json();",
        "if (json.accessToken) pm.collectionVariables.set('managerToken', json.accessToken);"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin@billing.vn\",\n  \"password\": \"123456\"\n}" },
        "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
      }
    },
    {
      "name": "TC-USER-01: Lấy danh sách user",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
        "pm.test('Trả về mảng', () => pm.expect(pm.response.json()).to.be.an('array'));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
      }
    },
    {
      "name": "TC-USER-02: Lấy user theo ID",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
      }
    },
    {
      "name": "TC-USER-03: Tạo tài khoản CONSULTANT",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
        "const json = pm.response.json();",
        "if (json.id) pm.collectionVariables.set('userId', json.id);"
      ] } }],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"consultant1@billing.vn\",\n  \"password\": \"123456\",\n  \"fullName\": \"Nguyễn Văn A\",\n  \"role\": \"CONSULTANT\"\n}" },
        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
      }
    },
    {
      "name": "TC-USER-04: Tạo user trùng username",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400 — trùng username', () => pm.response.to.have.status(400));"
      ] } }],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"consultant1@billing.vn\",\n  \"password\": \"123456\",\n  \"fullName\": \"Trùng Email\",\n  \"role\": \"CONSULTANT\"\n}" },
        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
      }
    },
    {
      "name": "TC-USER-05: Cập nhật thông tin user",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
      ] } }],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"consultant1@billing.vn\",\n  \"password\": \"newpass123\",\n  \"fullName\": \"Nguyễn Văn A (Updated)\",\n  \"role\": \"CONSULTANT\"\n}" },
        "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
      }
    },
    {
      "name": "TC-USER-06: Vô hiệu hoá tài khoản (disable)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 — enabled false', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().enabled).to.be.false; });"
      ] } }],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}/status?status=false", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}","status"], "query": [{"key":"status","value":"false"}] }
      }
    },
    {
      "name": "TC-USER-07: Kích hoạt lại tài khoản",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 — enabled true', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().enabled).to.be.true; });"
      ] } }],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}/status?status=true", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}","status"], "query": [{"key":"status","value":"true"}] }
      }
    },
    {
      "name": "TC-USER-08: Xoá user",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 204 No Content', () => pm.response.to.have.status(204));"
      ] } }],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
      }
    },
    {
      "name": "TC-USER-09: CONSULTANT gọi /users bị từ chối",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{consultantToken}}" }],
        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
      }
    }
  ]
}
