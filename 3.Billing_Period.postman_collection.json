{
  "info": {
    "name": "3. Billing Period (Kỳ Cước)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "managerToken", "value": "" },
    { "key": "consultantToken", "value": "" },
    { "key": "periodId", "value": "" }
  ],
  "item": [
    {
      "name": "TC-BP-01: Lấy danh sách kỳ cước",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
        "const arr = pm.response.json();",
        "if (Array.isArray(arr) && arr.length > 0) pm.collectionVariables.set('periodId', arr[0].id);"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/billing-periods", "host": ["{{baseUrl}}"], "path": ["billing-periods"] }
      }
    },
    {
      "name": "TC-BP-02: Lấy kỳ cước theo ID",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/billing-periods/{{periodId}}", "host": ["{{baseUrl}}"], "path": ["billing-periods","{{periodId}}"] }
      }
    },
    {
      "name": "TC-BP-03: Lấy kỳ cước ID không tồn tại",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/billing-periods/9999", "host": ["{{baseUrl}}"], "path": ["billing-periods","9999"] }
      }
    },
    {
      "name": "TC-BP-04: Import đầu kỳ (file Excel hợp lệ)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
        "pm.test('Có successCount failCount errors', () => { const j = pm.response.json(); pm.expect(j).to.have.all.keys('successCount','failCount','errors'); });"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "", "description": "⚠️ Chọn file Excel mẫu .xlsx" }] },
        "url": { "raw": "{{baseUrl}}/billing-periods/import", "host": ["{{baseUrl}}"], "path": ["billing-periods","import"] }
      }
    },
    {
      "name": "TC-BP-05: Import file không phải Excel",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "", "description": "⚠️ Chọn file .pdf hoặc .csv để test lỗi" }] },
        "url": { "raw": "{{baseUrl}}/billing-periods/import", "host": ["{{baseUrl}}"], "path": ["billing-periods","import"] }
      }
    },
    {
      "name": "TC-BP-06: CONSULTANT import bị từ chối",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{consultantToken}}" }],
        "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }] },
        "url": { "raw": "{{baseUrl}}/billing-periods/import", "host": ["{{baseUrl}}"], "path": ["billing-periods","import"] }
      }
    },
    {
      "name": "TC-BP-07: Đóng kỳ cước",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200 — CLOSED', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('CLOSED'); });"
      ] } }],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/billing-periods/{{periodId}}/close", "host": ["{{baseUrl}}"], "path": ["billing-periods","{{periodId}}","close"] }
      }
    },
    {
      "name": "TC-BP-08: Đóng kỳ đã đóng rồi",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400 — kỳ đã đóng', () => pm.response.to.have.status(400));"
      ] } }],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
        "url": { "raw": "{{baseUrl}}/billing-periods/{{periodId}}/close", "host": ["{{baseUrl}}"], "path": ["billing-periods","{{periodId}}","close"] }
      }
    }
  ]
}
