      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}/bill-data",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}",
            "bill-data"
          ]
        }
      }
    },
    {
      "name": "TC-CR-15: Import đối chiếu gạch nợ",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — có successCount failCount', () => { pm.response.to.have.status(200); const j = pm.response.json(); pm.expect(j).to.have.all.keys('successCount','failCount'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "",
              "description": "⚠️ Chọn file đối chiếu .xlsx"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/records/import-reconciliation?periodId={{periodId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "import-reconciliation"
          ],
          "query": [
            {
              "key": "periodId",
              "value": "{{periodId}}"
            }
          ]
        }
      }
    },
