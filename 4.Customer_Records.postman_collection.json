{
  "info": {
    "name": "4. Customer Records (Hồ Sơ Khách Hàng)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "managerToken",
      "value": ""
    },
    {
      "key": "consultantToken",
      "value": ""
    },
    {
      "key": "periodId",
      "value": ""
    },
    {
      "key": "recordId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "TC-CR-01: Lấy danh sách records (MANAGER — xem tất cả)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const items = json.content || json;",
              "if (Array.isArray(items) && items.length > 0) pm.collectionVariables.set('recordId', items[0].id);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ]
        }
      }
    },
    {
      "name": "TC-CR-02: Lấy records (CONSULTANT — chỉ xem của mình)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consultantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ]
        }
      }
    },
    {
      "name": "TC-CR-03: Filter theo periodId",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records?periodId={{periodId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ],
          "query": [
            {
              "key": "periodId",
              "value": "{{periodId}}"
            }
          ]
        }
      }
    },
    {
      "name": "TC-CR-04: Filter theo status CHUA_THU",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records?status=CHUA_THU",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ],
          "query": [
            {
              "key": "status",
              "value": "CHUA_THU"
            }
          ]
        }
      }
    },
    {
      "name": "TC-CR-05: Filter theo địa chỉ",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records?province=Hà Nội&ward=Phường X",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ],
          "query": [
            {
              "key": "province",
              "value": "Hà Nội"
            },
            {
              "key": "ward",
              "value": "Phường X"
            }
          ]
        }
      }
    },
    {
      "name": "TC-CR-06: Tìm kiếm tự do (search)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records?search=Nguyễn Văn",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ],
          "query": [
            {
              "key": "search",
              "value": "Nguyễn Văn"
            }
          ]
        }
      }
    },
    {
      "name": "TC-CR-07: Phân trang (page=0, size=5)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "pm.test('Có totalElements totalPages', () => { const j = pm.response.json(); pm.expect(j).to.have.property('totalElements'); pm.expect(j).to.have.property('totalPages'); pm.expect(j.content.length).to.be.at.most(5); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records?page=0&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records"
          ],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      }
    },
    {
      "name": "TC-CR-08: Lấy chi tiết 1 record",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}"
          ]
        }
      }
    },
    {
      "name": "TC-CR-09: CONSULTANT lấy record không thuộc mình",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403 hoặc 404', () => pm.expect(pm.response.code).to.be.oneOf([403,404]));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{consultantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}"
          ]
        }
      }
    },
    {
      "name": "TC-CR-10: Thu tiền và in bill (CHUA_THU → DA_IN_BILL)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — DA_IN_BILL', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('DA_IN_BILL'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"collectedAmount\": 250000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}/print-bill",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}",
            "print-bill"
          ]
        }
      }
    },
    {
      "name": "TC-CR-11: In bill record đã in rồi",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 — trạng thái không hợp lệ', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"collectedAmount\": 250000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}/print-bill",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}",
            "print-bill"
          ]
        }
      }
    },
    {
      "name": "TC-CR-12: Gạch nợ (DA_IN_BILL → DA_GACH_NO)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — DA_GACH_NO', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('DA_GACH_NO'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}/mark-debt",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}",
            "mark-debt"
          ]
        }
      }
    },
    {
      "name": "TC-CR-13: Gạch nợ record chưa in bill",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/records/{{recordId}}/mark-debt",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "records",
            "{{recordId}}",
            "mark-debt"
          ]
        }
      }
    },
    {
