    {
      "name": "5. Customer Records (Danh sách thu cước)",
      "description": "MANAGER xem toàn khu vực, CONSULTANT chỉ xem của mình.",
      "item": [
        {
          "name": "GET Records (tháng hiện tại)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (json.content && json.content.length > 0) {",
                  "  pm.collectionVariables.set('recordId', json.content[0].id);",
                  "  console.log('✅ recordId saved:', json.content[0].id);",
                  "  console.log('Total records:', json.totalElements);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/records?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["records"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "month", "value": "6", "disabled": true },
                { "key": "year", "value": "2026", "disabled": true },
                { "key": "collectionStatus", "value": "CHUA_THU", "disabled": true },
                { "key": "debtStatus", "value": "CHUA_GACH_NO", "disabled": true },
                { "key": "assignedUserId", "value": "", "disabled": true },
                { "key": "billPrintedDate", "value": "2026-06-01", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET Records (lọc theo tháng/năm)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/records?month=6&year=2026&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["records"],
              "query": [
                { "key": "month", "value": "6" },
                { "key": "year", "value": "2026" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET Export Records to Excel",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/records/export?month=6&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["records", "export"],
              "query": [
                { "key": "month", "value": "6" },
                { "key": "year", "value": "2026" },
                { "key": "collectionStatus", "value": "CHUA_THU", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "POST Create Record (Manual - MANAGER/ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
