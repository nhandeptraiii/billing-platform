            "url": { "raw": "{{baseUrl}}/records/{{recordId}}", "host": ["{{baseUrl}}"], "path": ["records", "{{recordId}}"] }
          }
        },
        {
          "name": "PATCH Print Bill / Thu tiền",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('collectionStatus = DA_THANH_TOAN', () => pm.expect(json.collectionStatus).to.eql('DA_THANH_TOAN'));",
