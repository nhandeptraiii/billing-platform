{
  "info": {
    "name": "Billing Platform APIs v3 (Region)",
    "description": "API collection cập nhật với tính năng Khu vực (Region), Role ADMIN/MANAGER/CONSULTANT. Luồng: Tạo Region → Tạo User với regionId → Login → Test APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "managerToken", "value": "" },
    { "key": "consultantToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "regionId", "value": "" },
    { "key": "periodId", "value": "" },
    { "key": "recordId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "  console.log('✅ Token saved:', json.accessToken.substring(0, 40) + '...');",
                  "} else {",
                  "  console.log('❌ No token in response:', JSON.stringify(json));",
                  "}",
                  "pm.test('Login thành công', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login (MANAGER) - Save managerToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('managerToken', json.accessToken);",
                  "  console.log('✅ Manager token saved');",
                  "}",
                  "pm.test('Manager login thành công', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"manager_test\",\n  \"password\": \"Test@12345\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
          }
        },
        {
          "name": "Get Current Account (/account)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Response có regionId', () => pm.expect(json).to.have.property('regionId'));",
                  "pm.test('Response có regionName', () => pm.expect(json).to.have.property('regionName'));",
                  "console.log('User region:', json.regionId, json.regionName);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/account", "host": ["{{baseUrl}}"], "path": ["account"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/logout", "host": ["{{baseUrl}}"], "path": ["logout"] }
          }
        }
      ]
    },
    {
      "name": "2. Region (Khu Vực) - NEW",
      "description": "Quản lý khu vực. ADMIN tạo và sửa, tất cả roles có thể xem danh sách.",
      "item": [
        {
          "name": "GET All Regions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  pm.collectionVariables.set('regionId', json[0].id);",
                  "  console.log('✅ regionId saved:', json[0].id, '-', json[0].name);",
                  "} else {",
                  "  console.log('⚠️ Danh sách region rỗng. Hãy tạo region trước!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/regions", "host": ["{{baseUrl}}"], "path": ["regions"] }
          }
        },
        {
          "name": "POST Create Region (ADMIN only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Tạo region thành công', () => pm.response.to.have.status(200));",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('regionId', json.id);",
                  "  console.log('✅ regionId saved:', json.id, '-', json.name);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Huyện Thạch Thất\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/regions", "host": ["{{baseUrl}}"], "path": ["regions"] }
          }
        },
        {
          "name": "PUT Update Region (ADMIN only)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Huyện Thạch Thất (Updated)\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/regions/{{regionId}}", "host": ["{{baseUrl}}"], "path": ["regions", "{{regionId}}"] }
          }
        }
      ]
    },
    {
      "name": "3. User Management",
      "description": "MANAGER và ADMIN quản lý user. Bắt buộc truyền regionId khi tạo/sửa user.",
      "item": [
        {
          "name": "GET Current User (Me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Response có regionId', () => pm.expect(json).to.have.property('regionId'));",
                  "console.log('Role:', json.role, '| Region:', json.regionId, json.regionName);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "GET Users (with filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "keyword", "value": "", "disabled": true },
                { "key": "role", "value": "CONSULTANT", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "POST Create User (MANAGER / ADMIN) - CÓ regionId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Tạo user thành công', () => pm.response.to.have.status(201));",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('userId', json.id);",
                  "  console.log('✅ userId saved:', json.id);",
                  "  console.log('Region:', json.regionId, json.regionName);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"manager_test\",\n  \"fullName\": \"Nguyen Van Manager\",\n  \"phone\": \"0912345678\",\n  \"password\": \"Test@12345\",\n  \"role\": \"MANAGER\",\n  \"regionId\": {{regionId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "POST Create CONSULTANT User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"consultant01\",\n  \"fullName\": \"Tran Thi Consultant\",\n  \"phone\": \"0901234567\",\n  \"password\": \"Test@12345\",\n  \"role\": \"CONSULTANT\",\n  \"regionId\": {{regionId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "GET User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "PUT Update User (CÓ regionId)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van Manager (Updated)\",\n  \"phone\": \"0912345678\",\n  \"role\": \"MANAGER\",\n  \"regionId\": {{regionId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "PATCH Update User Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/status?status=INACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "status"],
              "query": [{ "key": "status", "value": "INACTIVE" }]
            }
          }
        },
        {
          "name": "PUT Reset User Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"Test@12345\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}/reset-password", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "reset-password"] }
          }
        },
        {
          "name": "PUT Change My Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"newpass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/me/password", "host": ["{{baseUrl}}"], "path": ["users", "me", "password"] }
          }
        },
        {
          "name": "POST Import Consultants (MANAGER/ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "Chọn file mẫu nhân viên (.xlsx)" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/users/import-consultants", "host": ["{{baseUrl}}"], "path": ["users", "import-consultants"] }
          }
        },
        {
          "name": "DELETE User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        }
      ]
    },
    {
