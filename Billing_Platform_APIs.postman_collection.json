            },
            "url": { "raw": "{{baseUrl}}/records/{{recordId}}/print-bill", "host": ["{{baseUrl}}"], "path": ["records", "{{recordId}}", "print-bill"] }
          }
        },
        {
          "name": "PATCH Mark Debt / Gạch nợ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('debtStatus = DA_GACH_NO', () => pm.expect(json.debtStatus).to.eql('DA_GACH_NO'));",
                  "console.log('✅ Debt marked. Status:', json.debtStatus);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/records/{{recordId}}/mark-debt", "host": ["{{baseUrl}}"], "path": ["records", "{{recordId}}", "mark-debt"] }
          }
        },
        {
          "name": "GET Bill Data (cho Mobile in bill)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/records/{{recordId}}/bill-data", "host": ["{{baseUrl}}"], "path": ["records", "{{recordId}}", "bill-data"] }
          }
        },
        {
          "name": "PATCH Bulk Mark Debt (theo periodId)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{managerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/records/bulk-mark-debt?periodId={{periodId}}",
              "host": ["{{baseUrl}}"],
              "path": ["records", "bulk-mark-debt"],
              "query": [{ "key": "periodId", "value": "{{periodId}}" }]
            }
          }
        },
        {
          "name": "PATCH Bulk Mark Debt (với bộ lọc)",
          "request": {
            "method": "PATCH",
